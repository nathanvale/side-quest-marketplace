{
	"schemaVersion": "0.1.0",
	"name": "PARA Bookmark",
	"behavior": "create",
	"noteNameFormat": "{{title|safe_name}}",
	"path": "00 Inbox",
	"noteContentFormat": "{{content|slice:0,2000}}\n\n---\n*Clipped from [{{domain}}]({{url}}) on {{date}}*",
	"properties": [
		{
			"name": "type",
			"value": "bookmark",
			"type": "text"
		},
		{
			"name": "title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "url",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{date}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		}
	],
	"triggers": []
}

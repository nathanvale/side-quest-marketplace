{
	"name": "@sidequest/kit",
	"version": "1.0.0",
	"private": true,
	"description": "Kit plugin for Claude Code",
	"type": "module",
	"scripts": {
		"test": "bun test --recursive",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"kit-index": "bun run src/cli.ts",
		"prime": "bun run src/cli.ts prime",
		"find": "bun run src/cli.ts find",
		"overview": "bun run src/cli.ts overview",
		"stats": "bun run src/cli.ts stats"
	},
	"dependencies": {
		"@side-quest/core": "^0.1.1",
		"tree-sitter-wasms": "^0.1.13",
		"web-tree-sitter": "^0.25.10"
	},
	"devDependencies": {
		"@types/bun": "latest"
	}
}

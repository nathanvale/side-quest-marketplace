{
	"name": "@sidequest/validate-plugin",
	"version": "1.0.0",
	"private": true,
	"description": "PostToolUse hook to validate plugin files (marketplace.json, plugin.json, hooks.json) after edits",
	"type": "module",
	"scripts": {
		"test": "bun test",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"format:check": "biome format .",
		"lint": "biome lint .",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@sidequest/core": "workspace:*"
	}
}

{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/../core/bootstrap.sh",
						"timeout": 60
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Read|Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/validate-plugin.ts",
						"timeout": 30
					}
				]
			}
		]
	}
}

{
	"description": "Git intelligence hooks: context, safety, logging, cortex, auto-commit",
	"hooks": {
		"SessionStart": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/git-context-loader.ts",
						"timeout": 15
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/git-safety.ts",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/command-logger.ts",
						"timeout": 5
					}
				]
			}
		],
		"PreCompact": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.ts",
						"timeout": 15
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/auto-commit-on-stop.ts",
						"timeout": 10
					}
				]
			}
		]
	}
}

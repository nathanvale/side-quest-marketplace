{
	"description": "Obsidian PARA method integration with CLI operations and MCP server",
	"hooks": {
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/session-summary.ts",
						"timeout": 10
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Skill",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/brain-telemetry.ts",
						"timeout": 5,
						"async": true
					}
				]
			},
			{
				"matcher": "Write|Edit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/skill-lint.ts",
						"timeout": 5
					}
				]
			}
		]
	}
}

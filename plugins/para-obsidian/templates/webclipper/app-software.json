{
	"schemaVersion": "0.1.0",
	"name": "App / Software",
	"behavior": "create",
	"noteNameFormat": "✂️📱 {{title|safe_name|slice:0,70}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n![App Icon]({{image}})\n\n## App Info\n\n| | |\n|---|---|\n| **Price** | `= this.price` |\n| **Rating** | `= this.rating`/5 |\n| **Category** | `= this.category` |\n| **Platform** | `= this.platform` |\n\n## Why I'm Interested\n\n\n\n## Description\n\n{{description}}\n\n---\n\n[Download](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "app",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "price",
			"value": "{{schema:@SoftwareApplication:offers.price}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@SoftwareApplication:aggregateRating.ratingValue}}",
			"type": "text"
		},
		{
			"name": "category",
			"value": "{{schema:@SoftwareApplication:applicationCategory}}",
			"type": "text"
		},
		{
			"name": "platform",
			"value": "{{schema:@SoftwareApplication:operatingSystem}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@SoftwareApplication",
		"https://apps.apple.com",
		"https://play.google.com/store/apps"
	]
}

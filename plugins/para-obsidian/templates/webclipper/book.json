{
	"schemaVersion": "0.1.0",
	"name": "Book",
	"behavior": "create",
	"noteNameFormat": "✂️📚 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n![Cover]({{image}})\n\n## Book Info\n\n| | |\n|---|---|\n| **Author** | `= this.author` |\n| **Pages** | `= this.pages` |\n| **Rating** | `= this.rating`/5 |\n| **Genre** | `= this.genre` |\n| **ISBN** | `= this.isbn` |\n\n## Why I Want to Read This\n\n\n\n## Description\n\n{{description}}\n\n## Notes\n\n{{highlights}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "book",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "author",
			"value": "{{schema:@Book:author.name}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@Book:aggregateRating.ratingValue}}",
			"type": "text"
		},
		{
			"name": "pages",
			"value": "{{schema:@Book:numberOfPages}}",
			"type": "text"
		},
		{
			"name": "genre",
			"value": "{{schema:@Book:genre}}",
			"type": "text"
		},
		{
			"name": "isbn",
			"value": "{{schema:@Book:isbn}}",
			"type": "text"
		},
		{
			"name": "consumption_status",
			"value": "to-read",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Book",
		"https://goodreads.com/book",
		"https://www.goodreads.com/book"
	]
}

{
	"schemaVersion": "0.1.0",
	"name": "Podcast Episode",
	"behavior": "create",
	"noteNameFormat": "✂️🎙️ {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"context": "{{schema:@PodcastEpisode}}",
	"noteContentFormat": "# `= this.file.name`\n\n## AI Summary\n\n{{\"Summarize this content in 3 concise bullet points, focusing on the key insights and actionable takeaways\"|blockquote}}\n\n---\n\n![Podcast Art]({{image}})\n\n## Episode Info\n\n| | |\n|---|---|\n| **Show** | `= this.show` |\n| **Duration** | `= this.duration` |\n| **Published** | `= this.published` |\n\n## Why I Want to Listen\n\n\n\n## Description\n\n{{description}}\n\n---\n\n🎧 [Listen](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "podcast",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "show",
			"value": "{{schema:@PodcastEpisode:partOfSeries.name}}",
			"type": "text"
		},
		{
			"name": "duration",
			"value": "{{schema:@PodcastEpisode:duration}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{schema:@PodcastEpisode:datePublished}}",
			"type": "date"
		},
		{
			"name": "consumption_status",
			"value": "to-listen",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@PodcastEpisode",
		"https://podcasts.apple.com",
		"https://open.spotify.com/episode",
		"https://overcast.fm"
	]
}

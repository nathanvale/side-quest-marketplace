{
    "schemaVersion": "0.1.0",
    "name": "Capture",
    "behavior": "create",
    "noteNameFormat": "✂️ {{title|safe_name|slice:0,80|trim}}",
    "path": "00 Inbox",
    "noteContentFormat": "# `= this.file.name`\n\n**Source:** [{{domain}}]({{url}})\n**Clipped:** {{time|date:\"YYYY-MM-DD HH:mm\"}}\n\n---\n\n## Highlights\n\n{{highlights|map:item => item.text|list}}\n\n---\n\n## Content\n\n{{content}}",
    "properties": [
        { "name": "type", "value": "clipping", "type": "text" },
        { "name": "clipping_type", "value": "", "type": "text" },
        { "name": "source", "value": "{{url}}", "type": "text" },
        {
            "name": "clipped",
            "value": "{{time|date:\"YYYY-MM-DD\"}}",
            "type": "date"
        },
        { "name": "domain", "value": "{{domain}}", "type": "text" },
        { "name": "distill_status", "value": "raw", "type": "text" }
    ],
    "triggers": []
}

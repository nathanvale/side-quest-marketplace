{
	"schemaVersion": "0.1.0",
	"name": "Article",
	"behavior": "create",
	"noteNameFormat": "✂️📰 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n**Author:** `= this.author`\n**Published:** `= this.published`\n**Source:** [`= this.domain`](`= this.source`)\n\n---\n\n## Summary\n\n{{description}}\n\n## Highlights\n\n{{highlights}}\n\n## Full Content\n\n{{content|slice:0,15000}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "article",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "author",
			"value": "{{author}}",
			"type": "text"
		},
		{
			"name": "published",
			"value": "{{published}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": ["schema:@Article", "schema:@BlogPosting", "schema:@NewsArticle"]
}

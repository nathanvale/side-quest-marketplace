{
	"schemaVersion": "0.1.0",
	"name": "Job Posting",
	"behavior": "create",
	"noteNameFormat": "✂️💼 {{title|safe_name|slice:0,70}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n## Job Details\n\n| | |\n|---|---|\n| **Company** | `= this.company` |\n| **Location** | `= this.location` |\n| **Type** | `= this.employment_type` |\n| **Salary** | `= this.salary` |\n| **Posted** | `= this.posted` |\n\n## Why I'm Interested\n\n\n\n## Description\n\n{{description}}\n\n---\n\n💼 [Apply](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "job",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "company",
			"value": "{{schema:@JobPosting:hiringOrganization.name}}",
			"type": "text"
		},
		{
			"name": "job_title",
			"value": "{{schema:@JobPosting:title}}",
			"type": "text"
		},
		{
			"name": "location",
			"value": "{{schema:@JobPosting:jobLocation.address.addressLocality}}",
			"type": "text"
		},
		{
			"name": "employment_type",
			"value": "{{schema:@JobPosting:employmentType}}",
			"type": "text"
		},
		{
			"name": "salary",
			"value": "{{schema:@JobPosting:baseSalary.value}}",
			"type": "text"
		},
		{
			"name": "posted",
			"value": "{{schema:@JobPosting:datePosted}}",
			"type": "date"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@JobPosting",
		"https://linkedin.com/jobs",
		"https://www.linkedin.com/jobs",
		"https://indeed.com/viewjob",
		"https://www.indeed.com/viewjob",
		"https://seek.com.au/job",
		"https://www.seek.com.au/job"
	]
}

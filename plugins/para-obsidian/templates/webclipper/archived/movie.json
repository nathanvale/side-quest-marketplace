{
	"schemaVersion": "0.1.0",
	"name": "Movie",
	"behavior": "create",
	"noteNameFormat": "✂️🎬 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n![Poster]({{image}})\n\n## Movie Info\n\n| | |\n|---|---|\n| **Year** | `= this.year` |\n| **Director** | `= this.director` |\n| **Rating** | `= this.rating`/10 |\n| **Runtime** | `= this.runtime` |\n| **Genre** | `= this.genre` |\n\n## Why I Want to Watch This\n\n\n\n## Description\n\n{{description}}\n\n## Notes\n\n{{highlights}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "movie",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "year",
			"value": "{{schema:@Movie:datePublished}}",
			"type": "text"
		},
		{
			"name": "director",
			"value": "{{schema:@Movie:director.name}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@Movie:aggregateRating.ratingValue}}",
			"type": "text"
		},
		{
			"name": "runtime",
			"value": "{{schema:@Movie:duration}}",
			"type": "text"
		},
		{
			"name": "genre",
			"value": "{{schema:@Movie:genre}}",
			"type": "text"
		},
		{
			"name": "consumption_status",
			"value": "to-watch",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Movie",
		"https://imdb.com/title",
		"https://www.imdb.com/title"
	]
}

{
	"schemaVersion": "0.1.0",
	"name": "Restaurant",
	"behavior": "create",
	"noteNameFormat": "вњ‚пёЏрџЌЅпёЏ {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n## At a Glance\n\n| | |\n|---|---|\n| **Cuisine** | `= this.cuisine` |\n| **Price Range** | `= this.price_range` |\n| **Rating** | `= this.rating`/5 |\n| **Suburb** | `= this.suburb` |\n| **Address** | `= this.address` |\n| **Phone** | `= this.phone` |\n\n## Hours\n\n`= this.hours`\n\n## Why I Want to Try This\n\n\n\n## Notes\n\n{{highlights}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "restaurant",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "cuisine",
			"value": "{{schema:@Restaurant:servesCuisine}}",
			"type": "text"
		},
		{
			"name": "price_range",
			"value": "{{schema:@Restaurant:priceRange}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@Restaurant:aggregateRating.ratingValue}}",
			"type": "text"
		},
		{
			"name": "suburb",
			"value": "{{schema:@Restaurant:address.addressLocality}}",
			"type": "text"
		},
		{
			"name": "address",
			"value": "{{schema:@Restaurant:address.streetAddress}}",
			"type": "text"
		},
		{
			"name": "phone",
			"value": "{{schema:@Restaurant:telephone}}",
			"type": "text"
		},
		{
			"name": "hours",
			"value": "{{schema:@Restaurant:openingHours}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Restaurant",
		"schema:@FoodEstablishment",
		"schema:@LocalBusiness",
		"https://yelp.com/biz",
		"https://www.yelp.com/biz",
		"https://tripadvisor.com/Restaurant",
		"https://www.tripadvisor.com/Restaurant",
		"https://zomato.com",
		"https://www.zomato.com"
	]
}

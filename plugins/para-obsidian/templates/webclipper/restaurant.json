{
	"schemaVersion": "0.1.0",
	"name": "Restaurant",
	"behavior": "create",
	"noteNameFormat": "✂️🍽️ {{schema:@Restaurant:name|default:title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"context": "{{schema:@Restaurant}}",
	"noteContentFormat": "# {{title}}\n\n## At a Glance\n\n| | |\n|---|---|\n| **Cuisine** | `= this.cuisine` |\n| **Price Range** | `= this.price_range` |\n| **Rating** | `= this.rating`/5 |\n| **Suburb** | `= this.suburb` |\n| **Address** | {{schema:@Restaurant:address.streetAddress|default:\"—\"}} |\n| **Phone** | {{schema:@Restaurant:telephone|default:\"—\"}} |\n\n## Hours\n\n{{schema:@Restaurant:openingHours|default:\"Check website\"}}\n\n## Why I Want to Try This\n\n\n\n## Notes\n\n{{highlights|default:\"\"}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "restaurant",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "cuisine",
			"value": "{{schema:@Restaurant:servesCuisine|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "price_range",
			"value": "{{schema:@Restaurant:priceRange|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@Restaurant:aggregateRating.ratingValue|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "suburb",
			"value": "{{schema:@Restaurant:address.addressLocality|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Restaurant",
		"schema:@FoodEstablishment",
		"schema:@LocalBusiness",
		"https://yelp.com/biz",
		"https://www.yelp.com/biz",
		"https://tripadvisor.com/Restaurant",
		"https://www.tripadvisor.com/Restaurant",
		"https://zomato.com",
		"https://www.zomato.com"
	]
}

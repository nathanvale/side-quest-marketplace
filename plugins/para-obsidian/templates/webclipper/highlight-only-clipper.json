{
	"schemaVersion": "0.1.0",
	"name": "Highlight Only",
	"behavior": "create",
	"noteContentFormat": "# `= this.file.name`\n\n{{highlights}}\n\n---\n\n🔗 [Source](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "highlight",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "source_title",
			"value": "{{title}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"noteNameFormat": "✂️✨ {{title|safe_name|slice:0,60}}",
	"path": "00 Inbox"
}

{
	"schemaVersion": "0.1.0",
	"name": "Product / Gift Idea",
	"behavior": "create",
	"noteNameFormat": "🎁 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"context": "{{schema:@Product}}",
	"noteContentFormat": "# {{title}}\n\n![Product Image]({{schema:@Product:image|default:meta:og:image}})\n\n## Details\n\n**Price:** `= this.price` `= this.currency`\n\n**Brand:** `= this.brand`\n\n**Rating:** `= this.rating`/5\n\n**Gift For:** `= this.gift_for`\n\n## Why I Clipped This\n\n\n\n## Notes\n\n{{highlights|default:\"\"}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "product",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "price",
			"value": "{{schema:@Product:offers.price|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "currency",
			"value": "{{schema:@Product:offers.priceCurrency|default:\"AUD\"}}",
			"type": "text"
		},
		{
			"name": "brand",
			"value": "{{schema:@Product:brand.name|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "rating",
			"value": "{{schema:@Product:aggregateRating.ratingValue|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "gift_for",
			"value": "",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Product",
		"https://amazon.com",
		"https://www.amazon.com",
		"https://amazon.co.uk",
		"https://www.amazon.co.uk",
		"https://amazon.com.au",
		"https://www.amazon.com.au",
		"https://etsy.com/listing",
		"https://www.etsy.com/listing",
		"https://ebay.com/itm",
		"https://www.ebay.com/itm"
	]
}

{
	"schemaVersion": "0.1.0",
	"name": "Claude Conversation",
	"behavior": "create",
	"noteNameFormat": "🤖 {{title|safe_name|slice:0,60}}",
	"path": "00 Inbox",
	"context": "{{selectorHtml:body|markdown}}",
	"noteContentFormat": "# {{title}}\n\n**Saved:** `= this.clipped`\n**Model:** `= this.ai_model`\n\n## Why I Saved This\n\n\n\n## Conversation\n\n{{content|slice:0,20000}}\n\n---\n\n**Source:** [`= this.ai_model`](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "ai-conversation",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "ai_model",
			"value": "Claude",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": ["https://claude.ai"]
}

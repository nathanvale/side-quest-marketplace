{
	"schemaVersion": "0.1.0",
	"name": "Recipe",
	"behavior": "create",
	"noteNameFormat": "✂️🍳 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n![Recipe]({{image}})\n\n## Quick Info\n\n| | |\n|---|---|\n| **Prep Time** | `= this.prep_time` |\n| **Cook Time** | `= this.cook_time` |\n| **Total Time** | `= this.total_time` |\n| **Servings** | `= this.servings` |\n| **Cuisine** | `= this.cuisine` |\n| **Calories** | `= this.calories` |\n\n## Ingredients\n\n{{schema:@Recipe:recipeIngredient|list}}\n\n## Instructions\n\n{{schema:@Recipe:recipeInstructions}}\n\n## Notes\n\n{{highlights}}\n\n---\n\n**Source:** [`= this.source`](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "recipe",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "prep_time",
			"value": "{{schema:@Recipe:prepTime}}",
			"type": "text"
		},
		{
			"name": "cook_time",
			"value": "{{schema:@Recipe:cookTime}}",
			"type": "text"
		},
		{
			"name": "total_time",
			"value": "{{schema:@Recipe:totalTime}}",
			"type": "text"
		},
		{
			"name": "servings",
			"value": "{{schema:@Recipe:recipeYield}}",
			"type": "text"
		},
		{
			"name": "cuisine",
			"value": "{{schema:@Recipe:recipeCuisine}}",
			"type": "text"
		},
		{
			"name": "calories",
			"value": "{{schema:@Recipe:nutrition.calories}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": ["schema:@Recipe"]
}

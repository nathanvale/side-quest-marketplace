{
	"schemaVersion": "0.1.0",
	"name": "Tweet / X Post",
	"behavior": "create",
	"noteNameFormat": "🐦 {{selector:[data-testid=\"User-Name\"] span|first|default:\"someone\"|safe_name}} - {{time|date:\"YYYY-MM-DD\"}}",
	"path": "00 Inbox",
	"context": "{{selectorHtml:body|markdown}}",
	"noteContentFormat": "# Tweet by {{selector:[data-testid=\"User-Name\"]|first|default:\"Unknown\"}}\n\n{{selector:[data-testid=\"tweetText\"]|first|default:content}}\n\n---\n\n**Posted:** `= this.clipped`\n**Link:** [View on X](`= this.source`)\n\n## Why I Saved This\n\n",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "tweet",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"https://twitter.com",
		"https://x.com"
	]
}
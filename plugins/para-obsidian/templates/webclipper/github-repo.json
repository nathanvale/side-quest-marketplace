{
	"schemaVersion": "0.1.0",
	"name": "GitHub Repo",
	"behavior": "create",
	"noteNameFormat": "✂️💻 {{title|split:\":\"|first|safe_name}}",
	"path": "00 Inbox",
	"context": "{{selectorHtml:article.markdown-body|markdown}}",
	"noteContentFormat": "# `= this.file.name`\n\n## AI Summary\n\n{{\"Summarize this content in 3 concise bullet points, focusing on the key insights and actionable takeaways\"|blockquote}}\n\n---\n\n{{description}}\n\n## Quick Info\n\n| | |\n|---|---|\n| **URL** | [`= this.source`](`= this.source`) |\n| **Language** | `= this.language` |\n| **License** | `= this.license` |\n\n## Why I'm Interested\n\n\n\n## README\n\n{{selectorHtml:article.markdown-body|markdown|slice:0,50000}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "repo",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "language",
			"value": "{{selector:[itemprop=\"programmingLanguage\"]}}",
			"type": "text"
		},
		{
			"name": "license",
			"value": "{{selector:.octicon-law + span}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": ["/^https:\\/\\/github\\.com\\/[^\\/]+\\/[^\\/]+\\/?$/"]
}

{
	"schemaVersion": "0.1.0",
	"name": "Course / Tutorial",
	"behavior": "create",
	"noteNameFormat": "✂️🎓 {{schema:@Course:name|default:title|safe_name|slice:0,70}}",
	"path": "00 Inbox",
	"context": "{{schema:@Course}}",
	"noteContentFormat": "# {{title}}\n\n## AI Summary\n\n{{\"Summarize this content in 3 concise bullet points, focusing on the key insights and actionable takeaways\"|blockquote}}\n\n---\n\n![Course Image]({{schema:@Course:image|default:meta:og:image}})\n\n## Course Info\n\n| | |\n|---|---|\n| **Instructor** | `= this.instructor` |\n| **Price** | `= this.price` |\n| **Rating** | {{schema:@Course:aggregateRating.ratingValue|default:\"—\"}}/5 |\n| **Duration** | {{schema:@Course:timeRequired|default:\"—\"}} |\n\n## Why I Want to Take This\n\n\n\n## Description\n\n{{description|default:\"\"}}\n\n---\n\n🎓 [Enroll](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "course",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "instructor",
			"value": "{{schema:@Course:provider.name|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "price",
			"value": "{{schema:@Course:offers.price|default:\"\"}}",
			"type": "text"
		},
		{
			"name": "consumption_status",
			"value": "to-learn",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Course",
		"https://udemy.com/course",
		"https://www.udemy.com/course",
		"https://coursera.org/learn",
		"https://www.coursera.org/learn",
		"https://skillshare.com/classes",
		"https://www.skillshare.com/classes",
		"https://masterclass.com/classes"
	]
}

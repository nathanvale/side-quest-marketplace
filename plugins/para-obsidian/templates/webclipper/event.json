{
	"schemaVersion": "0.1.0",
	"name": "Event",
	"behavior": "create",
	"noteNameFormat": "✂️📅 {{title|safe_name|slice:0,80}}",
	"path": "00 Inbox",
	"noteContentFormat": "# `= this.file.name`\n\n![Event Image]({{image}})\n\n## Event Details\n\n| | |\n|---|---|\n| **Date** | `= this.event_date` |\n| **End** | `= this.event_end` |\n| **Location** | `= this.location` |\n| **Address** | `= this.address` |\n| **Price** | `= this.price` |\n| **Organizer** | `= this.organizer` |\n\n## Why I'm Interested\n\n\n\n## Description\n\n{{description}}\n\n---\n\n🎫 [Get Tickets](`= this.source`)",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "event",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "event_date",
			"value": "{{schema:@Event:startDate}}",
			"type": "date"
		},
		{
			"name": "event_end",
			"value": "{{schema:@Event:endDate}}",
			"type": "text"
		},
		{
			"name": "location",
			"value": "{{schema:@Event:location.name}}",
			"type": "text"
		},
		{
			"name": "address",
			"value": "{{schema:@Event:location.address}}",
			"type": "text"
		},
		{
			"name": "price",
			"value": "{{schema:@Event:offers.price}}",
			"type": "text"
		},
		{
			"name": "organizer",
			"value": "{{schema:@Event:organizer.name}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"schema:@Event",
		"https://eventbrite.com",
		"https://www.eventbrite.com",
		"https://eventbrite.com.au",
		"https://www.eventbrite.com.au",
		"https://meetup.com/events",
		"https://www.meetup.com/events"
	]
}

{
	"schemaVersion": "0.1.0",
	"name": "Documentation",
	"behavior": "create",
	"noteNameFormat": "✂️📖 {{title|safe_name|slice:0,70}}",
	"path": "00 Inbox",
	"context": "{{selectorHtml:main|markdown}}",
	"noteContentFormat": "# `= this.file.name`\n\n## AI Summary\n\n{{\"Summarize this content in 3 concise bullet points, focusing on the key insights and actionable takeaways\"|blockquote}}\n\n---\n\n**Source:** [`= this.domain`](`= this.source`)\n\n---\n\n{{content|slice:0,12000}}\n\n---\n\n## Why I Saved This\n\n\n\n## Key Snippets\n\n{{highlights}}",
	"properties": [
		{
			"name": "type",
			"value": "clipping",
			"type": "text"
		},
		{
			"name": "clipping_type",
			"value": "documentation",
			"type": "text"
		},
		{
			"name": "source",
			"value": "{{url}}",
			"type": "text"
		},
		{
			"name": "clipped",
			"value": "{{time|date:\"YYYY-MM-DD\"}}",
			"type": "date"
		},
		{
			"name": "domain",
			"value": "{{domain}}",
			"type": "text"
		},
		{
			"name": "distill_status",
			"value": "raw",
			"type": "text"
		},
		{
			"name": "related",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "project",
			"value": "",
			"type": "multitext"
		},
		{
			"name": "area",
			"value": "",
			"type": "multitext"
		}
	],
	"triggers": [
		"https://docs.github.com",
		"https://developer.mozilla.org",
		"https://docs.python.org",
		"https://nodejs.org/docs",
		"https://help.obsidian.md",
		"https://docs.anthropic.com"
	]
}

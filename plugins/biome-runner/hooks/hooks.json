{
	"description": "Auto-format and lint files using Biome (git-aware)",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/biome-check.ts",
						"timeout": 30
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/biome-ci.ts",
						"timeout": 60
					},
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/metrics-summary.ts",
						"timeout": 10
					}
				]
			}
		]
	}
}

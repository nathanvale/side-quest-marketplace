{
	"name": "@sidequest/claude-code",
	"version": "1.0.0",
	"private": true,
	"description": "Claude Code documentation plugin - maintains up-to-date docs from Eric Buess's repository",
	"type": "module",
	"scripts": {
		"test": "bun test --recursive",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",

		"lint": "biome lint .",
		"check": "biome check --write ."
	},
	"dependencies": {
		"@sidequest/core": "workspace:*",
		"cheerio": "^1.1.2",
		"turndown": "^7.2.2",
		"xml2js": "^0.6.2"
	},
	"devDependencies": {
		"@types/turndown": "^5.0.6",
		"@types/xml2js": "^0.4.14"
	}
}

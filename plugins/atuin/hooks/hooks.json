{
	"description": "Atuin shell history integration hooks",
	"hooks": {
		"SessionStart": [
			{
				"matcher": "startup",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/install-deps.sh",
						"timeout": 30
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "Bash",
				"hooks": [
					{
						"type": "command",
						"command": "${CLAUDE_PLUGIN_ROOT}/hooks/atuin-post-tool.sh",
						"timeout": 5
					}
				]
			}
		]
	}
}

{
	"description": "Biome linter/formatter hooks: incremental post-edit check, MCP dedup adapter, and full project check on stop",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/biome-check.ts",
						"timeout": 30
					}
				]
			},
			{
				"matcher": "mcp__.*biome-runner__(biome_lintCheck|biome_lintFix|biome_formatCheck)",
				"hooks": [
					{
						"type": "command",
						"command": "SQ_HOOK_DEDUP_ENABLED=1 bunx @side-quest/claude-hooks posttool",
						"timeout": 5
					}
				]
			}
		],
		"PostToolUseFailure": [
			{
				"matcher": "mcp__.*biome-runner__(biome_lintCheck|biome_lintFix|biome_formatCheck)",
				"hooks": [
					{
						"type": "command",
						"command": "SQ_HOOK_DEDUP_ENABLED=1 bunx @side-quest/claude-hooks posttool-failure",
						"timeout": 5
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "*",
				"hooks": [
					{
						"type": "command",
						"command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/biome-ci.ts",
						"timeout": 120
					}
				]
			}
		]
	}
}

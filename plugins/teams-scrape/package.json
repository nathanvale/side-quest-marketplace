{
	"name": "@sidequest/teams-scrape",
	"version": "1.0.0",
	"description": "Microsoft Teams chat extraction with persistence and new message detection",
	"type": "module",
	"main": "./src/index.ts",
	"bin": {
		"teams-scrape": "./src/cli.ts"
	},
	"scripts": {
		"test": "bun test --recursive",
		"typecheck": "tsc --noEmit",
		"format": "biome format --write .",
		"lint": "biome lint .",
		"check": "biome check --write .",
		"cli": "bun run ./src/cli.ts"
	},
	"keywords": [
		"teams",
		"chat",
		"microsoft",
		"macos-automation",
		"scraping"
	],
	"author": {
		"name": "Nathan Vale",
		"email": "hi@nathanvale.com"
	},
	"devDependencies": {
		"@types/bun": "latest"
	},
	"dependencies": {
		"@side-quest/core": "^0.1.1"
	}
}

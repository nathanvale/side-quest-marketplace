{
  "description": "Auto-format and lint files on write/edit using Biome",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "bun run ${CLAUDE_PLUGIN_ROOT}/hooks/biome-check.ts",
            "timeout": 30
          }
        ]
      }
    ]
  }
}

{
	"name": "side-quest-marketplace",
	"version": "1.0.0",
	"private": true,
	"description": "SideQuest - ADHD-friendly Claude Code plugin marketplace",
	"workspaces": [
		"core",
		"plugins/*",
		"plugins/*/mcp-servers/*"
	],
	"scripts": {
		"test": "bun run --filter '*' test",
		"typecheck": "bun run --filter '*' typecheck",
		"format": "bun run biome format --write .",
		"format:check": "bun run biome format .",
		"lint": "bun run biome lint .",
		"check": "bun run biome check --write .",
		"ci": "bun --filter '*' typecheck && bun run check && bun --filter '*' test",
		"validate": "bun run core/src/validate/cli.ts --all",
		"ci:full": "bun run ci && bun run validate",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.3.7",
		"@commitlint/cli": "^20.1.0",
		"@commitlint/config-conventional": "^20.0.0",
		"bun-types": "^1.3.3",
		"husky": "^9.1.7",
		"typescript": "^5.7.2"
	}
}

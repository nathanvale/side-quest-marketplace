{
	"name": "nathan-vale-claude-code",
	"version": "1.0.0",
	"private": true,
	"description": "Nathan Vale's Claude Code plugin marketplace",
	"workspaces": ["plugins/*"],
	"scripts": {
		"test": "bun run --filter '*' test",
		"typecheck": "bun run --filter '*' typecheck",
		"format": "bun run --filter '*' format",
		"format:check": "bun run --filter '*' format:check",
		"lint": "bun run --filter '*' lint",
		"check": "bun run --filter '*' check",
		"ci": "bun --filter '*' typecheck && bunx @biomejs/biome check . && bun --filter '*' test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"bun-types": "^1.3.3",
		"husky": "^9.1.7"
	}
}
